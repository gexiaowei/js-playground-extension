{
  "name": "javascript-playground-extension",
  "private": true,
  "version": "1.1.0",
  "scripts": {
    "lint": "eslint devtools.js panel.js scripts/*.mjs",
    "build:crx": "node scripts/build-crx.mjs",
    "sync:manifest-version": "node scripts/sync-manifest-version.mjs",
    "release": "release-it",
    "release:ci": "release-it --ci"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "crx": "^5.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "release-it": "^20.0.0"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): v${version}",
      "tagName": "v${version}"
    },
    "github": {
      "release": false
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "after:bump": [
        "pnpm sync:manifest-version",
        "pnpm build:crx"
      ]
    }
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
