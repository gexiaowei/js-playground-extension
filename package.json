{
  "name": "javascript-playground-extension",
  "private": true,
  "version": "1.3.0",
  "repository": {
    "type": "git",
    "url": "git@github.com:gexiaowei/js-playground-extension.git"
  },
  "scripts": {
    "lint": "eslint devtools.js panel.js scripts/*.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "build:crx": "node scripts/build-crx.mjs",
    "sync:manifest-version": "node scripts/sync-manifest-version.mjs",
    "release": "release-it",
    "release:ci": "release-it --ci"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "crx": "^5.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "release-it": "^20.0.0"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): v${version}",
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "after:bump": [
        "pnpm sync:manifest-version"
      ]
    }
  },
  "packageManager": "pnpm@10.33.0"
}
