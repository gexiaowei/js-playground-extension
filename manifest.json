{
  "manifest_version": 3,
  "name": "JavaScript Playground",
  "version": "1.0.0",
  "description": "在Chrome DevTools中添加一个JavaScript Playground标签页",
  "devtools_page": "devtools.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": [
    "activeTab"
  ]
}
